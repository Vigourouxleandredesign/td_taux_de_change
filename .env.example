# Clé API (https://www.exchangerate-api.com/) — requise pour npm run fetch:rates et pour la prod Netlify
VUE_APP_EXCHANGE_RATE_API_KEY=

# Dev : JSON local par défaut (aucun appel API). Mettre "false" pour tester l'API en local.
# Prod (build Netlify) : API live automatiquement.
# VUE_APP_USE_LOCAL_RATES=true
