# Clé API (https://www.exchangerate-api.com/)
# — Local : npm run fetch:rates et tests API directs (dev uniquement)
# — Netlify : variable EXCHANGE_RATE_API_KEY (sans préfixe VUE_APP_, côté Function uniquement)
EXCHANGE_RATE_API_KEY=

# Ancien nom encore accepté par fetch:rates en local :
# VUE_APP_EXCHANGE_RATE_API_KEY=

# Dev : JSON local par défaut (aucun appel API). Mettre "false" pour tester l'API en local.
# Prod (build Netlify) : proxy /.netlify/functions/rates (cache serveur 1 h).
# VUE_APP_USE_LOCAL_RATES=true
